                },
                "password": {
                    "type": "password",
                    "label": "password",
                    "newLine": true
                }
            }
        },
        "python": {
            "type": "panel",
            "label": "python",
            "items": {
                "pythonExecutable": {
                    "type": "text",
                    "label": "pythonExecutable",
